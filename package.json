{
  "name": "auroraflow",
  "version": "1.0.0",
  "description": "TypeScript Playwright test automation framework with resilient page objects, Redis-backed selector data, self-healing diagnostics, and CI observability artifacts.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./playwright": {
      "types": "./dist/playwright.d.ts",
      "require": "./dist/playwright.js",
      "default": "./dist/playwright.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "husky",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "pack:dry-run": "npm pack --dry-run",
    "format": "prettier . --write",
    "format:check": "prettier . --check --cache --cache-location .cache/prettier",
    "lint": "eslint . --cache --cache-location .cache/eslint",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit --incremental --tsBuildInfoFile .cache/tsconfig.tsbuildinfo",
    "test": "npm run test:unit",
    "test:unit": "vitest run tests/suites/unit --pool=threads --no-isolate --testTimeout=30000",
    "test:coverage": "npm run test:coverage:critical && npm run test:coverage:global",
    "test:contracts": "vitest run tests/suites/contracts --config=configs/vitest.contracts.mts",
    "test:integration": "vitest run tests/suites/integration",
    "test:integration:all": "npm run test:integration && npm run test:contracts",
    "test:smoke": "npx playwright test --config=configs/playwright.config.ts --project='Google Chrome' --grep @smoke --timeout=60000 --workers=1",
    "test:examples": "npx playwright test --config=configs/playwright.config.ts tests/suites/e2e/examples --project='Google Chrome'",
    "test:e2e": "npx playwright test --config=configs/playwright.config.ts",
    "infra:redis:up": "docker compose up -d redis",
    "infra:redis:down": "docker compose down --remove-orphans",
    "infra:redis:logs": "docker compose logs --tail=200 redis",
    "observability:up": "docker compose -f docker-compose.yml -f docker-compose.observability.yml up -d",
    "observability:down": "docker compose -f docker-compose.yml -f docker-compose.observability.yml down --remove-orphans",
    "observability:logs": "docker compose -f docker-compose.yml -f docker-compose.observability.yml logs --tail=200 otel-collector prometheus grafana jaeger elasticsearch logstash kibana",
    "observability:smoke": "AURORAFLOW_OBSERVABILITY_ENABLED=true AURORAFLOW_OBSERVABILITY_ENVIRONMENT=local OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318 npm run observability:ci:smoke",
    "observability:ci:smoke": "node -r ts-node/register scripts/observability-ci-smoke.ts",
    "observability:snapshot": "node -r ts-node/register scripts/observability-export-snapshot.ts",
    "observability:live-assert": "node -r ts-node/register scripts/observability-live-export-assert.ts",
    "test:integration:local": "npm run infra:redis:up && npm run test:integration",
    "test-report": "npx playwright show-report test-reports",
    "self-heal:governance": "node scripts/self-healing-governance.mjs",
    "self-heal:promotions": "node -r ts-node/register scripts/self-healing-promotions.ts",
    "self-heal:cleanup": "node -r ts-node/register scripts/self-healing-registry-cleanup.ts",
    "flakiness:report": "node -r ts-node/register scripts/flakiness-report.ts",
    "slo:dashboard": "node -r ts-node/register scripts/slo-dashboard.ts",
    "slo:alerts": "node -r ts-node/register scripts/slo-alerts.ts",
    "schemas:check": "node scripts/run-schemas-check.mjs",
    "tools:actionlint": "bash scripts/install-actionlint.sh",
    "verify:tools": "npm run tools:actionlint",
    "workflows:lint": "npm run tools:actionlint --silent && node scripts/workflows-lint.mjs",
    "workflows:security": "npm run security:workflows",
    "shellcheck": "PATH=\"$HOME/.local/bin:$PATH\" shellcheck scripts/*.sh",
    "security:audit": "npm audit --audit-level=high",
    "security:workflows": "pipx run --spec zizmor==1.26.1 zizmor .github/workflows",
    "security:all": "npm run security:audit && npm run security:workflows",
    "security:check": "npm run security:all",
    "verify": "npm run verify:tools && npm run format:check && npm run lint && npm run typecheck && npm run test:unit && npm run test:contracts && npm run test:integration && npm run schemas:check && npm run shellcheck && npm run workflows:lint:check",
    "verify:smoke": "npm run verify && npm run test:smoke",
    "test:coverage:critical": "vitest run tests/suites/unit/framework/selfHealing/artifactPrivacy.spec.ts tests/suites/unit/framework/selfHealing/config.spec.ts tests/suites/unit/framework/selfHealing/guardedValidation.spec.ts tests/suites/unit/framework/selfHealing/historyRepository.spec.ts tests/suites/unit/framework/selfHealing/promotionWorkflow.spec.ts tests/suites/unit/framework/selfHealing/registryRuntime.spec.ts tests/suites/unit/framework/observability/trends.spec.ts --coverage",
    "test:coverage:global": "vitest run tests/suites/unit --config=configs/vitest.coverage-global.mts --coverage",
    "test:mutation": "node scripts/mutation-baseline.mjs",
    "test:mutation:check": "node scripts/mutation-baseline.mjs --check",
    "test:e2e:guarded": "npm run test:e2e -- --project='Google Chrome' --grep 'guarded self-heal' --workers=2",
    "workflows:lint:check": "node scripts/workflows-lint.mjs",
    "postverify": "node scripts/verify-stamp.mjs write"
  },
  "engines": {
    "node": ">=20 <25"
  },
  "keywords": [
    "playwright",
    "test-automation",
    "self-healing-tests",
    "redis",
    "observability"
  ],
  "author": "Juan Pedro Sugg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsugg/auroraflow.git"
  },
  "bugs": {
    "url": "https://github.com/jsugg/auroraflow/issues"
  },
  "homepage": "https://github.com/jsugg/auroraflow#readme",
  "peerDependencies": {
    "playwright": ">=1.59 <2",
    "@playwright/test": ">=1.59 <2"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "actionlint": "^2.0.6",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "playwright": "^1.59.1",
    "prettier": "^3.8.4",
    "testcontainers": "^12.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.sh": [
      "shellcheck"
    ]
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^5.12.1"
  },
  "overrides": {
    "diff": "^4.0.4",
    "minimatch@10.2.5": {
      "brace-expansion": "^5.0.6"
    },
    "archiver-utils": {
      "glob": "^13.0.6"
    }
  }
}
