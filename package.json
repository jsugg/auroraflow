{
  "name": "play-on-sports",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "prepare": "husky",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:e2e",
    "test:unit": "vitest run tests/suites/unit tests/suites/framework --passWithNoTests",
    "test:integration": "vitest run tests/suites/integration tests/suites/contracts --passWithNoTests",
    "test:smoke": "npx playwright test --config=configs/playwright.config.ts --project='Google Chrome'",
    "test:examples": "npx playwright test --config=configs/playwright.config.ts tests/suites/e2e/examples --project='Google Chrome'",
    "test:e2e": "npx playwright test --config=configs/playwright.config.ts",
    "test-report": "npx playwright show-report test-reports",
    "self-heal:governance": "node scripts/self-healing-governance.mjs",
    "workflows:lint": "node scripts/workflows-lint.mjs",
    "workflows:security": "pipx run zizmor .github/workflows",
    "shellcheck": "shellcheck scripts/*.sh",
    "security:check": "npm run workflows:security && npm audit --audit-level=high",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test:unit && npm run test:integration && npm run shellcheck && npm run workflows:lint",
    "verify:smoke": "npm run verify && npm run test:smoke"
  },
  "engines": {
    "node": ">=20 <25"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.19.39",
    "actionlint": "^2.0.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.59.1",
    "prettier": "^3.8.2",
    "testcontainers": "^11.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix"
    ],
    "*.sh": [
      "shellcheck"
    ]
  },
  "dependencies": {
    "redis": "^5.11.0"
  }
}
