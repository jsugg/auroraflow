{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auroraflow.dev/schemas/pending-selector-promotion.schema.json",
  "title": "AuroraFlow pending selector promotion",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "promotionId",
    "eventId",
    "candidateId",
    "selectorId",
    "proposedLocator",
    "locator",
    "confidence",
    "status",
    "requestedAt",
    "acknowledged"
  ],
  "properties": {
    "promotionId": {
      "type": "string",
      "minLength": 1
    },
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "candidateId": {
      "type": "string",
      "minLength": 1
    },
    "selectorId": {
      "type": "string",
      "minLength": 1
    },
    "locator": {
      "type": "string",
      "minLength": 1
    },
    "proposedLocator": {
      "type": "string",
      "minLength": 1
    },
    "baseSelectorVersion": {
      "$ref": "https://auroraflow.dev/schemas/_shared.schema.json#/$defs/nonNegativeInteger"
    },
    "confidence": {
      "$ref": "https://auroraflow.dev/schemas/_shared.schema.json#/$defs/ratio"
    },
    "status": {
      "enum": ["pending", "approved", "applied", "rejected", "conflict", "rolled_back"]
    },
    "requestedAt": {
      "$ref": "https://auroraflow.dev/schemas/_shared.schema.json#/$defs/isoDateTime"
    },
    "expiresAt": {
      "$ref": "https://auroraflow.dev/schemas/_shared.schema.json#/$defs/isoDateTime"
    },
    "runId": {
      "type": "string"
    },
    "testId": {
      "type": "string"
    },
    "pageObjectName": {
      "type": "string"
    },
    "actionType": {
      "$ref": "https://auroraflow.dev/schemas/_shared.schema.json#/$defs/selfHealingActionType"
    },
    "acknowledged": {
      "type": "boolean"
    },
    "reviewedBy": {
      "type": "string"
    },
    "reviewedAt": {
      "$ref": "https://auroraflow.dev/schemas/_shared.schema.json#/$defs/isoDateTime"
    },
    "reviewReason": {
      "type": "string"
    },
    "conflictReason": {
      "type": "string"
    },
    "appliedAt": {
      "$ref": "https://auroraflow.dev/schemas/_shared.schema.json#/$defs/isoDateTime"
    },
    "appliedSelectorVersion": {
      "$ref": "https://auroraflow.dev/schemas/_shared.schema.json#/$defs/nonNegativeInteger"
    },
    "previousLocator": {
      "type": "string"
    },
    "previousConfidence": {
      "$ref": "https://auroraflow.dev/schemas/_shared.schema.json#/$defs/ratio"
    },
    "previousStrategy": {
      "type": "string"
    },
    "previousNotes": {
      "type": "string"
    },
    "rolledBackAt": {
      "$ref": "https://auroraflow.dev/schemas/_shared.schema.json#/$defs/isoDateTime"
    }
  }
}
